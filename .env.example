# ───────────────────────── OmniSense environment ────────────────────────────
# Keep secrets out of git. This is the template — copy real values into `.env`.

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=replace-me-with-32-bytes-of-randomness
OMNISENSE_DATA_DIR=./.omnisense-data

# ─── Initial admin (created on first boot only) ────────────────────────────
ADMIN_EMAIL=admin@omnisense.local
ADMIN_PASSWORD=changeme123

# ─── LLM (OpenRouter recommended — cheap pay-per-token) ────────────────────
# Used by Commander AI + all NLP enrichment + report writing.
# Sign up: https://openrouter.ai/keys
LLM_MODEL=qwen/qwen3.6-plus
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# ─── Persistence (optional — defaults to local JSON file) ──────────────────
# Azure Postgres Flex / any Postgres. Falls back to file under OMNISENSE_DATA_DIR.
DATABASE_URL=

# ─── Report file storage (optional — uploads HTML reports to Azure Blob) ───
# Container-scoped SAS URL with write permission. Falls back to API download.
DATA_STORAGE_SAS_URL=

# Browser-like request identity for public web/media fetches.
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# ─── Web Search Waterfall (in priority order: free first) ──────────────────
# 1. SearXNG — self-host (https://docs.searxng.org). FREE, unlimited.
SEARXNG_BASE_URL=
# 2. DuckDuckGo — no key required, scraped (rate-limited). FREE.
# 3. Brave Search — 2,000 queries/month free. https://api.search.brave.com
BRAVE_API_KEY=
# 4. Tavily — 1,000 queries/month free, pay-as-you-go. https://app.tavily.com
TAVILY_API_KEY=

# ─── News & Open data (OSINT-first) ────────────────────────────────────────
# GDELT — NO KEY, free, global news + sentiment. Always enabled.
# RSS — NO KEY, point at any RSS/Atom feed URL.
# NewsAPI.org — 100 requests/day on dev tier. https://newsapi.org/register
NEWSAPI_KEY=

# ─── Social scraping provider (paid, preferred where official APIs are limited) ─
# EnsembleData supports TikTok, Instagram, YouTube, Twitter/X, Reddit, Threads, Twitch, Snapchat.
# It does NOT expose a Facebook endpoint in the current OpenAPI spec, so Facebook uses Graph API fallback.
# Sign up: https://dashboard.ensembledata.com/register
ENSEMBLEDATA_TOKEN=
ENSEMBLEDATA_BASE_URL=https://ensembledata.com/apis

# ─── Social platforms (most require paid/restricted API access) ─────────────
# Reddit — public .json endpoints, NO KEY. Always enabled.
# YouTube Data API v3 — free tier 10k units/day. https://console.cloud.google.com
YOUTUBE_API_KEY=
# X (Twitter) API v2 — Basic tier $200/mo. https://developer.twitter.com
X_BEARER_TOKEN=
# Facebook Graph API — Meta developer app required. https://developers.facebook.com
FACEBOOK_ACCESS_TOKEN=
# Instagram Graph API — Business account + Facebook app. https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=
# TikTok — preferred via EnsembleData. Official Research API fallback requires separate approval.
